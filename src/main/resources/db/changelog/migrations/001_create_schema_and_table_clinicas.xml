<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Schema: clinicas -->
    <changeSet id="001-1" author="gemini-cli">
        <sql>CREATE SCHEMA IF NOT EXISTS clinicas;</sql>
    </changeSet>

    <!-- Tabela: clinicas.clinicas -->
    <changeSet id="001-2" author="gemini-cli">
        <createTable tableName="clinicas" schemaName="clinicas">
            <column name="identificador_fiscal" type="VARCHAR(14)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nome_exibicao" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="tipo_pessoa" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="registro_conselho_clinica" type="VARCHAR(50)"/>
            <column name="tipo_clinica" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="ativo" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            
            <!-- Colunas de Auditoria Padrão -->
            <column name="criado_em" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="atualizado_em" type="TIMESTAMP"/>
            <column name="excluido_em" type="TIMESTAMP"/>
            <column name="versao" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
